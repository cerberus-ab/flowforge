{
  "semi": true,
  "tabWidth": 4,
  "printWidth": 120,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "overrides": [
    {
      "files": "**/{*,.*}.json",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": "**/*.{css,scss}",
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    }
  ]
}
