# Configuration
PORT=3477
NODE_ENV=development
LOG_LEVEL=info

# Indexer Settings
INDEXER_CHUNK_SIZE=500
INDEXER_CHUNK_OVERLAP_RATIO=0.10

# LLM Provider: 'ollama-local' | 'openai'
LLM_PROVIDER=openai

# === Ollama Local (LLM_PROVIDER=ollama-local) ===
# Self-hosted, free, no API key required
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_LOCAL_MODEL=llama3.1:8b
OLLAMA_LOCAL_EMBEDDING=nomic-embed-text

# === OpenAI (LLM_PROVIDER=openai) ===
# OpenAI API, requires API key
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Agent Settings
AGENT_TOOL_CALL_LIMIT=6
AGENT_RECURSION_LIMIT=10
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=1500
