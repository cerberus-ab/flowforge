{
  "name": "@flowforge/extension",
  "version": "0.1.3",
  "description": "Browser extension for AI-powered web application onboarding",
  "private": true,
  "main": "dist/chrome/action/popup/index.html",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:embed": "vite build --config vite.config.embed.ts && cp src/embed/flowforge-runtime.d.ts dist/embed/flowforge-runtime.d.ts",
    "build": "npm run clean && npm run typecheck && npm run build:chrome && npm run build:embed",
    "install:chrome": "node scripts/install-chrome.js",
    "dev:chrome": "vite build --config vite.config.chrome.ts --watch",
    "dev:embed": "vite build --config vite.config.embed.ts --watch",
    "dev": "concurrently \"npm run dev:chrome\" \"npm run dev:embed\"",
    "sandbox": "node sandbox/server.js"
  },
  "keywords": [
    "ai",
    "browser",
    "navigation",
    "onboarding",
    "rag",
    "agents",
    "user-flows",
    "user-experience"
  ],
  "dependencies": {
    "@flowforge/shared": "*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/chrome": "^0.1.38",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "marked": "^18.0.2",
    "preact": "^10.29.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
